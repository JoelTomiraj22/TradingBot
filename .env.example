# Binance Futures LIVE API Keys
BINANCE_API_KEY=your_live_api_key_here
BINANCE_API_SECRET=your_live_api_secret_here

# Binance Futures TESTNET API Keys (from https://testnet.binancefuture.com/)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Toggle: True = testnet, False = live
USE_TESTNET=True

# ─── AI Provider Keys ────────────────────────────────────────
# Priority chain: DeepSeek R1 (NVIDIA) -> Qwen3 235B (NVIDIA)
#                 -> Gemini 2.5 Pro/Flash -> OpenRouter free -> Groq
# Only ONE provider is required; the rest are fallbacks.

# 1. DeepSeek R1 via NVIDIA NIM (PRIMARY) — https://build.nvidia.com/
NVIDIA_DEEPSEEK_API_KEY=

# 2. Qwen3 235B via NVIDIA NIM (FALLBACK 1)
NVIDIA_QWEN_API_KEY=

# 3. Gemini 2.5 Pro keys, comma-separated (rotated on 429) — https://aistudio.google.com/apikey
GEMINI_PRO_API_KEYS=
# Gemini 2.5 Flash key (used after Pro keys are exhausted)
GEMINI_API_KEY=

# 4. OpenRouter free pool — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 5. Groq (LAST RESORT) — https://console.groq.com/
GROQ_API_KEY=

# Legacy generic NVIDIA key (fallback for both NVIDIA models)
NVIDIA_API_KEY=
